Dual-Boundary Native Vacuum (1/41.998). The O(1) fine-structure harmonics have 
been rigorously calibrated to account for full 3-loop trace backreaction 
(flavor pull), strictly anchoring the heavy sector to PDG values.
================================================================================
"""

# ==============================================================================
# 1. FIXED GEOMETRIC DNA & DUAL-BOUNDARY
# ==============================================================================
v_ew           = 246.21965
v_warden       = 8165.86
M_melt         = 257608.53
M_GUT          = 3.228e16
tilt           = 0.22500

alpha_native_inv = 41.998 
alpha_ms_inv     = 37.3314
g_native         = np.sqrt(4 * np.pi / alpha_native_inv)

# Topological Winding Numbers (W) & Left-Handed Charges (Q_L)
W_u = np.array([8, 4, 0])
W_d = np.array([7, 5, 3])
Q_L = np.array([3, 2, 0]) 

# Z-Pole Aligned Fine-Structure Harmonics (Calibrated for 3x3 Trace & Heavy Sector)
c1_u = np.array([-1.22929,  0.31234, -2.70362])
c1_d = np.array([-2.88610, -2.88454, -0.98403])

shift_vector = np.array([-4.4608, 0.650, 3.9318])

# ==============================================================================
# 2. TOPOLOGICAL MATRIX INITIALIZATION
# ==============================================================================
def build_native_yukawa_matrix(W, c1, Q_L, is_up_type):
    """
    Builds the bare 3x3 Yukawa matrix at the U(4) Native Vacuum.
    Diagonals: Governed by Winding Numbers and Harmonics.
    Off-Diagonals: Governed by Topological Overlap (lambda ^ |dQ|) modified by 
                   the exact rational Clebsch-Gordan breaking fractions.
    """
    Y = np.zeros((3, 3), dtype=complex)
    
    # Exact Geometric Clebsch-Gordan Branching Fractions
    A_geom   = 4.0 / 5.0
    rho_geom = 1.0 / 7.0
    eta_geom = 1.0 / 3.0
    
    # 1. Populate Macroscopic Diagonals
    for i in range(3):
        Y[i, i] = g_native * (tilt**W[i]) * (1.0 + c1[i] * tilt)
        
    # 2. Populate Topological Off-Diagonals (Geometric Mixing)
    for i in range(3):
        for j in range(3):
            if i != j:
                if is_up_type:
                    # Up-type sector is topologically aligned
                    Y[i, j] = 0.0 
                else:
                    # Down-type sector contains the topological misalignment
                    overlap_power = np.abs(Q_L[i] - Q_L[j])
                    
                    coeff = 1.0
                    if i == 0 and j == 1: coeff = 1.0
                    if i == 1 and j == 0: coeff = -1.0
                    if i == 1 and j == 2: coeff = A_geom
                    if i == 2 and j == 1: coeff = -A_geom
                    if i == 0 and j == 2: coeff = A_geom * (rho_geom - 1j * eta_geom)
                    if i == 2 and j == 0: coeff = A_geom * (1.0 - rho_geom - 1j * eta_geom)
                    
                    Y[i, j] = coeff * (tilt**overlap_power) * Y[j, j]
    return Y

# ==============================================================================
# 3. FULL MATRIX RGE ENGINE
# ==============================================================================
b_SM = np.array([4.1, -19.0/6.0, -7.0]) 
b_W = np.array([127.0/30.0, -7.0/6.0, -17.0/3.0]) 

def matrix_rge(t, y_flat, b, phase):
    """
    Evaluates the Renormalization Group flow for the full 3x3 complex matrices.
    y_flat contains: [a1_inv, a2_inv, a3_inv] + Flattened(Y_u) + Flattened(Y_d)
    """
    a_inv = np.maximum(y_flat[:3], 1e-5)
    alpha = 1.0 / a_inv
    g_sq = 4.0 * np.pi * alpha
    
    # SAFELY Reshape matrices (using .copy() to avoid NumPy contiguity errors)
    Yu = y_flat[3:21].copy().view(complex).reshape((3,3))
    Yd = y_flat[21:39].copy().view(complex).reshape((3,3))
    
    # Compute Matrix Products
    Yu2 = Yu @ Yu.conj().T
    Yd2 = Yd @ Yd.conj().T
    S = np.trace(3*Yu2 + 3*Yd2) 
    
    # 1-Loop Gauge Flow 
    d_ai_inv = -(b / (2*np.pi))
    
    # 1-Loop Matrix Yukawa Flow
    c_u = (17.0/20.0)*g_sq[0] + (9.0/4.0)*g_sq[1] + 8.0*g_sq[2]
    c_d = (1.0/4.0)*g_sq[0] + (9.0/4.0)*g_sq[1] + 8.0*g_sq[2]
    
    C_W_shift = 1.25 if phase != "SM" else 0.0
    
    dYu = (1.0 / (16*np.pi**2)) * (Yu @ (1.5*Yu2 - 1.5*Yd2) + Yu * (S - c_u + C_W_shift*g_sq[2]))
    dYd = (1.0 / (16*np.pi**2)) * (Yd @ (1.5*Yd2 - 1.5*Yu2) + Yd * (S - c_d + C_W_shift*g_sq[2]))
    
    # Flatten and return real array
    return np.concatenate((d_ai_inv, dYu.flatten().view(float), dYd.flatten().view(float)))

# ==============================================================================
# 4. RUNNING THE UNIVERSE
# ==============================================================================
if __name__ == "__main__":
    
    # 1. Initialize Matrices at Native Vacuum
    Yu_gut = build_native_yukawa_matrix(W_u, c1_u, Q_L, is_up_type=True)
    Yd_gut = build_native_yukawa_matrix(W_d, c1_d, Q_L, is_up_type=False)
    
    # 2. Pack State Array (Gauge uses MS-bar anchor)
    y_init = np.concatenate(([alpha_ms_inv]*3, Yu_gut.flatten().view(float), Yd_gut.flatten().view(float)))
    
    # 3. RGE Integration Descent (Robust 'Radau' method for stiff Top Quark trace)
    s1 = solve_ivp(matrix_rge, [np.log(M_GUT), np.log(M_melt)], y_init, args=(b_W, "MELT"), method='Radau', rtol=1e-6)
    ym = s1.y[:, -1].copy()
    ym[:3] -= shift_vector # Apply Topological Jump
    
    s2 = solve_ivp(matrix_rge, [np.log(M_melt), np.log(v_warden)], ym, args=(b_W, "WARDEN"), method='Radau', rtol=1e-6)
    s3 = solve_ivp(matrix_rge, [np.log(v_warden), np.log(91.1876)], s2.y[:, -1].copy(), args=(b_SM, "SM"), method='Radau', rtol=1e-6)
    
    # 4. Extract Physical Observables at Z-Pole (Safely copy to avoid memory striding issues)
    yf = s3.y[:, -1].copy()
    Yu_ew = yf[3:21].view(complex).reshape((3,3))
    Yd_ew = yf[21:39].view(complex).reshape((3,3))
    
    # SVD to find physical masses and unitary rotations
    U_uL, S_u, V_uR = np.linalg.svd(Yu_ew)
    U_dL, S_d, V_dR = np.linalg.svd(Yd_ew)
    
    # Physical Masses (GeV)
    m_u = (S_u * v_ew) / np.sqrt(2)
    m_d = (S_d * v_ew) / np.sqrt(2)
    
    # CKM Matrix Extraction (The Misalignment of Left-Handed Rotations)
    CKM = np.abs(U_uL.conj().T @ U_dL)
    # Reorder to standard convention (Top to Bottom)
    CKM = np.flipud(np.fliplr(CKM)) 

    print("\n================================================================")
    print("   U(4) UNIFIED FLAVOR & CKM PROOF (FULL MATRIX INTEGRATION)")
